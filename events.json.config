---
layout: null
permalink: /events.json
---
{% assign now = 'now' | date_to_xmlschema %}
{% assign events = site.events 
  | where_exp: 'event', 'event.endDate >= now and event.eventStatus != "EventRescheduled" and event.eventStatus != "EventCancelled"' 
  | sort: 'startDate' %}

[
  {% for event in events %}
    {% include event-ld.json event=event %}{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
